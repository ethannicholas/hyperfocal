    "Size of the majority vote that removes isolated wrong-depth patches at edges where the background shows through a defocused subject. 0 disables it.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Größe der Mehrheitsentscheidung, die vereinzelte Flecken falscher Tiefe an Kanten entfernt, wo der Hintergrund durch ein unscharfes Motiv durchscheint. 0 deaktiviert sie."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Tamaño del voto mayoritario que elimina parches aislados de profundidad errónea en bordes donde el fondo se transparenta a través de un sujeto desenfocado. 0 lo desactiva."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Taille du vote majoritaire qui supprime les taches isolées de profondeur erronée aux bords où l’arrière-plan transparaît à travers un sujet flou. 0 le désactive."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Dimensione del voto di maggioranza che rimuove le chiazze isolate di profondità errata ai bordi dove lo sfondo traspare attraverso un soggetto sfocato. 0 lo disattiva."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ピンボケの被写体越しに背景が透けて見えるエッジ部で、孤立した誤深度の斑点を除去する多数決のサイズです。0で無効になります。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "초점이 나간 피사체 너머로 배경이 비치는 가장자리에서 고립된 잘못된 깊이 패치를 제거하는 다수결의 크기입니다. 0이면 비활성화됩니다."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Grootte van de meerderheidsstemming die geïsoleerde plekken met verkeerde diepte verwijdert aan randen waar de achtergrond door een onscherp onderwerp heen schijnt. 0 schakelt dit uit."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Tamanho do voto majoritário que remove manchas isoladas de profundidade errada em bordas onde o fundo transparece através de um objeto desfocado. 0 desativa."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Размер мажоритарного голосования, убирающего одиночные пятна неверной глубины на краях, где фон просвечивает сквозь расфокусированный объект. 0 отключает."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "多数表决的范围大小，用于去除背景透过失焦主体显现的边缘处孤立的错误深度斑块。0 表示停用。"
          }
        }
      }
    },
