              },
              "one": {
                "stringUnit": {
                  "state": "translated",
                  "value": "%1$lld выровненный кадр экспортирован в «%2$@»."
                }
              },
              "other": {
                "stringUnit": {
                  "state": "translated",
                  "value": "%1$lld выровненного кадра экспортировано в «%2$@»."
                }
              }
            }
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "已将 %1$lld 张对齐图像导出到“%2$@”。"
          }
        }
      }
    },
