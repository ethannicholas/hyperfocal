    "Frames per second. 30 suits sharing; 60 is silkier and larger; 24 is filmic.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Bilder pro Sekunde. 30 eignet sich zum Teilen; 60 ist geschmeidiger und größer; 24 wirkt filmisch."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Fotogramas por segundo. 30 va bien para compartir; 60 es más fluido y pesado; 24 es cinematográfico."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Images par seconde. 30 convient au partage ; 60 est plus fluide et plus lourd ; 24 fait cinéma."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Fotogrammi al secondo. 30 va bene per condividere; 60 è più fluido e pesante; 24 è cinematografico."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "フレーム毎秒です。30は共有向き、60はより滑らかで大きく、24は映画的です。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "초당 프레임 수입니다. 30은 공유에 적합하고, 60은 더 부드럽지만 파일이 크며, 24는 영화 같은 느낌입니다."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Beelden per seconde. 30 is geschikt om te delen; 60 is vloeiender en groter; 24 is filmisch."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Quadros por segundo. 30 serve para compartilhar; 60 é mais fluido e maior; 24 é cinematográfico."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Кадров в секунду. 30 подходит для публикации; 60 — плавнее и тяжелее; 24 — киношно."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "每秒帧数。30 适合分享；60 更顺滑但更大；24 具有电影感。"
          }
        }
      }
    },
