    "Include this stack in Fuse Enabled Stacks. Doesn't change its per-frame checkboxes.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Diesen Stapel in „Aktivierte Stapel fusionieren“ einbeziehen. Ändert nicht seine Häkchen pro Einzelbild."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Incluye esta pila en «Fusionar pilas activadas». No cambia sus casillas por imagen."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Inclut cette pile dans « Fusionner les piles activées ». Ne change pas ses cases par image."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Include questa pila in “Fondi pile attive”. Non cambia le sue caselle per fotogramma."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "このスタックを「有効なスタックを合成」に含めます。フレームごとのチェックは変わりません。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "이 스택을 ‘활성화된 스택 합성’에 포함합니다. 프레임별 체크박스는 바뀌지 않습니다."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Neemt deze stapel op in ‘Ingeschakelde stapels samenvoegen’. Wijzigt de aankruisvakken per opname niet."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Inclui esta pilha em “Fundir Pilhas Ativadas”. Não altera as caixas por imagem."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Включает этот стек в «Объединить включённые стеки». Флажки отдельных кадров не меняются."
          }
        },
        "zh-Hans": {
