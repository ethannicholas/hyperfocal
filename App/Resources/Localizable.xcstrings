    "Any unsaved work in it will be lost.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Nicht gesicherte Änderungen darin gehen verloren."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Se perderá cualquier trabajo sin guardar que contenga."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Tout travail non enregistré qu’elle contient sera perdu."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Il lavoro non salvato al suo interno andrà perso."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "保存されていない作業内容は失われます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "저장되지 않은 작업은 사라집니다."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Niet-bewaard werk erin gaat verloren."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Qualquer trabalho não salvo nela será perdido."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Все несохранённые изменения в нём будут потеряны."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "其中所有未存储的工作都将丢失。"
          }
        }
      }
    },
