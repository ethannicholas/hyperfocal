        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "정렬된 프레임 %1$lld개를 ‘%2$@’(으)로 내보냈습니다."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "%1$lld uitgelijnde opnamen geëxporteerd naar ‘%2$@’."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "%1$lld imagens alinhadas exportadas para “%2$@”."
          }
        },
        "ru": {
          "variations": {
            "plural": {
              "few": {
