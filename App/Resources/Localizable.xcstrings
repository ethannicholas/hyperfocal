    "↑/↓ cycle source frames · space picks the sharpest frame for the brush region · p PMax result · r eraser · ⌥-scroll or [ ] resize the brush · scroll/pinch to navigate": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "↑/↓ Quellbilder durchschalten · Leertaste wählt das schärfste Bild für den Pinselbereich · p PMax-Ergebnis · r Radierer · ⌥-Scrollen oder [ ] ändert die Pinselgröße · Scrollen/Aufziehen zum Navigieren"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "↑/↓ recorre las imágenes de origen · espacio elige la más nítida bajo el pincel · p resultado PMax · r borrador · ⌥-desplazamiento o [ ] cambia el tamaño del pincel · desplázate/pellizca para navegar"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "↑/↓ parcourt les images sources · espace choisit l’image la plus nette sous le pinceau · p résultat PMax · r gomme · ⌥-défilement ou [ ] redimensionne le pinceau · défilement/pincement pour naviguer"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "↑/↓ scorre i fotogrammi sorgente · spazio sceglie il più nitido sotto il pennello · p risultato PMax · r gomma · ⌥-scorrimento o [ ] ridimensiona il pennello · scorri/pizzica per navigare"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "↑/↓でソースフレームを切り替え · スペースでブラシ領域が最も鮮明なフレームを選択 · pでPMax結果 · rで消しゴム · ⌥スクロールまたは[ ]でブラシサイズ変更 · スクロール/ピンチで移動"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "↑/↓ 소스 프레임 전환 · 스페이스 바로 브러시 영역이 가장 선명한 프레임 선택 · p PMax 결과 · r 지우개 · ⌥-스크롤 또는 [ ]로 브러시 크기 조절 · 스크롤/핀치로 이동"
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "↑/↓ wisselt bronopnamen · spatie kiest de scherpste opname onder het penseel · p PMax-resultaat · r gum · ⌥-scrollen of [ ] wijzigt de penseelgrootte · scrol/knijp om te navigeren"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "↑/↓ alterna as imagens de origem · espaço escolhe a mais nítida sob o pincel · p resultado PMax · r apagador · ⌥-rolagem ou [ ] redimensiona o pincel · role/belisque para navegar"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "↑/↓ — перебор исходных кадров · пробел — самый резкий кадр под кистью · p — результат PMax · r — ластик · ⌥-прокрутка или [ ] — размер кисти · прокрутка/жест сведения — навигация"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "↑/↓ 切换源图像 · 空格键选取画笔区域最清晰的图像 · p PMax 结果 · r 擦除 · ⌥-滚动或 [ ] 调整画笔大小 · 滚动/捏合以导航"
          }
        }
      }
    }
  },
  "version": "1.0"
}
