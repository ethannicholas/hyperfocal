    "%lld aligned frames exported to “%@”.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "%1$lld ausgerichtete Einzelbilder nach „%2$@“ exportiert."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "%1$lld imágenes alineadas exportadas a «%2$@»."
