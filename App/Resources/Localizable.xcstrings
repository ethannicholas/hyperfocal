    "S-curve around the midtones: positive deepens shadows and brightens highlights, negative flattens.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "S-Kurve um die Mitteltöne: positiv vertieft Schatten und hellt Lichter auf, negativ flacht ab."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Curva en S alrededor de los medios tonos: en positivo profundiza las sombras y aclara las iluminaciones; en negativo aplana."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Courbe en S autour des tons moyens : positif renforce les ombres et éclaircit les hautes lumières, négatif aplatit."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Curva a S attorno ai mezzitoni: positivo scurisce le ombre e schiarisce le luci, negativo appiattisce."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "中間調を中心としたSカーブ。プラスでシャドウが深くハイライトが明るくなり、マイナスでフラットになります。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "미드톤 중심의 S 커브입니다. 양수는 그림자를 깊게 하고 하이라이트를 밝게 하며, 음수는 평탄하게 만듭니다."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "S-curve rond de middentonen: positief verdiept schaduwen en verheldert hoge lichten, negatief maakt vlakker."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Curva em S ao redor dos meios-tons: positivo aprofunda sombras e clareia realces, negativo achata."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "S-кривая вокруг средних тонов: положительные значения углубляют тени и осветляют света, отрицательные — сглаживают."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "围绕中间调的 S 曲线：正值加深阴影、提亮高光，负值使影调变平。"
          }
        }
      }
    },
