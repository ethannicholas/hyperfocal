    "No Metal device available — fusing runs on the CPU.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Kein Metal-Gerät verfügbar — die Fusion läuft auf der CPU."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "No hay dispositivo Metal disponible: la fusión se ejecuta en la CPU."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Aucun périphérique Metal disponible — la fusion s’exécute sur le CPU."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Nessun dispositivo Metal disponibile — la fusione gira sulla CPU."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Metalデバイスがありません — 合成はCPUで実行されます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "사용 가능한 Metal 장비가 없습니다. 합성은 CPU에서 실행됩니다."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Geen Metal-apparaat beschikbaar — samenvoegen draait op de CPU."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Nenhum dispositivo Metal disponível — a fusão roda na CPU."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Устройство Metal недоступно — объединение выполняется на CPU."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "没有可用的 Metal 设备 — 合成将在 CPU 上运行。"
          }
        }
      }
    },
    "No alignment yet — fuse the stack (with alignment on) first.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Noch keine Ausrichtung — zuerst den Stapel (mit aktivierter Ausrichtung) fusionieren."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Aún no hay alineación: fusiona primero la pila (con la alineación activada)."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Pas encore d’alignement — fusionnez d’abord la pile (avec l’alignement activé)."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Nessun allineamento ancora — fondi prima la pila (con l’allineamento attivo)."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "まだ位置合わせがありません — まず（位置合わせを有効にして）スタックを合成してください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "아직 정렬이 없습니다. 먼저 (정렬을 켠 상태로) 스택을 합성하세요."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Nog geen uitlijning — voeg eerst de stapel samen (met uitlijnen aan)."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Ainda sem alinhamento — funda a pilha primeiro (com o alinhamento ativado)."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Выравнивания ещё нет — сначала объедините стек (с включённым выравниванием)."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "尚未对齐 — 请先（开启对齐）合成堆栈。"
          }
        }
      }
    },
    "No output yet": {
      "localizations": {
        "de": {
