    "Non-destructive crop: applies to every export and the rocking animation, and is saved with the project.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Nicht-destruktives Zuschneiden: gilt für jeden Export und die Parallaxen-Animation und wird mit dem Projekt gesichert."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Recorte no destructivo: se aplica a todas las exportaciones y a la animación de balanceo, y se guarda con el proyecto."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Recadrage non destructif : s’applique à chaque exportation et à l’animation de balancement, et s’enregistre avec le projet."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Ritaglio non distruttivo: si applica a ogni esportazione e all’animazione oscillante, e viene salvato con il progetto."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "非破壊トリミング。すべての書き出しとスイングアニメーションに適用され、プロジェクトと一緒に保存されます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "비파괴 자르기: 모든 내보내기와 로킹 애니메이션에 적용되며 프로젝트와 함께 저장됩니다."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Niet-destructief bijsnijden: geldt voor elke export en de kantelanimatie, en wordt met het project bewaard."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Corte não destrutivo: aplica-se a todas as exportações e à animação de balanço, e é salvo com o projeto."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Недеструктивное кадрирование: применяется к каждому экспорту и анимации покачивания и сохраняется вместе с проектом."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "非破坏性裁剪：应用于所有导出和摇摆动画，并随项目一起存储。"
