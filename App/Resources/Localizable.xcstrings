    "Stop building the PMax layer and go back to the previous brush source. Selecting PMax Result again restarts the build.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Berechnung der PMax-Ebene stoppen und zur vorherigen Pinselquelle zurückkehren. Erneutes Auswählen von PMax-Ergebnis startet die Berechnung neu."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Detiene la generación de la capa PMax y vuelve al origen de pincel anterior. Seleccionar de nuevo Resultado PMax reinicia la generación."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Arrête le calcul du calque PMax et revient à la source de pinceau précédente. Resélectionner Résultat PMax relance le calcul."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Ferma la generazione del livello PMax e torna alla sorgente precedente del pennello. Selezionare di nuovo Risultato PMax riavvia la generazione."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "PMaxレイヤーの生成を停止し、前のブラシソースに戻ります。PMax結果を再度選ぶと生成が再開されます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "PMax 레이어 생성을 중지하고 이전 브러시 소스로 돌아갑니다. PMax 결과를 다시 선택하면 생성이 다시 시작됩니다."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Stopt het genereren van de PMax-laag en keert terug naar de vorige penseelbron. PMax-resultaat opnieuw selecteren start het genereren opnieuw."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Interrompe a geração da camada PMax e volta à origem anterior do pincel. Selecionar Resultado PMax novamente reinicia a geração."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Останавливает построение слоя PMax и возвращает предыдущий источник кисти. Повторный выбор результата PMax запускает построение заново."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "停止生成 PMax 图层并返回上一个画笔来源。再次选择 PMax 结果会重新开始生成。"
          }
        }
      }
    },
