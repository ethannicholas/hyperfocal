          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Объединение"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "合成"
          }
        }
      }
    },
    "Fusion normally uses a disk cache to improve performance. This stack needs about %@ and the disk has %@ free. Fusion will be slower without a disk cache.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Die Fusion nutzt normalerweise einen Festplatten-Cache für bessere Leistung. Dieser Stapel benötigt etwa %1$@, frei sind %2$@. Ohne Cache ist die Fusion langsamer."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "La fusión normalmente usa una caché en disco para mejorar el rendimiento. Esta pila necesita unos %1$@ y el disco tiene %2$@ libres. Sin caché en disco, la fusión será más lenta."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "La fusion utilise normalement un cache disque pour de meilleures performances. Cette pile nécessite environ %1$@ et le disque dispose de %2$@ libres. Sans cache disque, la fusion sera plus lente."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "La fusione di norma usa una cache su disco per migliorare le prestazioni. Questa pila richiede circa %1$@ e il disco ha %2$@ liberi. Senza cache la fusione sarà più lenta."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "合成では通常、パフォーマンス向上のためディスクキャッシュを使用します。このスタックには約%1$@が必要ですが、ディスクの空きは%2$@です。キャッシュなしでは合成が遅くなります。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "합성은 보통 성능 향상을 위해 디스크 캐시를 사용합니다. 이 스택에는 약 %1$@이(가) 필요하지만 디스크 여유 공간은 %2$@입니다. 디스크 캐시 없이는 합성이 느려집니다."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Samenvoegen gebruikt normaal een schijfcache voor betere prestaties. Deze stapel heeft ongeveer %1$@ nodig en de schijf heeft %2$@ vrij. Zonder schijfcache is samenvoegen trager."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "A fusão normalmente usa um cache em disco para melhorar o desempenho. Esta pilha precisa de cerca de %1$@ e o disco tem %2$@ livres. Sem o cache, a fusão será mais lenta."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Объединение обычно использует дисковый кэш для ускорения. Этому стеку нужно около %1$@, а на диске свободно %2$@. Без кэша объединение будет медленнее."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "合成通常使用磁盘缓存来提高性能。此堆栈需要约 %1$@，而磁盘只有 %2$@ 可用。没有磁盘缓存时合成会更慢。"
          }
        }
      }
    },
