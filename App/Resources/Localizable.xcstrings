    "Cancel it or let it finish before adding stacks.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Vor dem Hinzufügen von Stapeln abbrechen oder abschließen lassen."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Cancélala o deja que termine antes de añadir pilas."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Annulez-la ou laissez-la se terminer avant d’ajouter des piles."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Annullala o lasciala finire prima di aggiungere pile."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "スタックを追加する前に、キャンセルするか完了を待ってください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "스택을 추가하기 전에 취소하거나 완료될 때까지 기다리세요."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Annuleer die of laat die eerst voltooien voordat u stapels toevoegt."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Cancele-a ou deixe-a terminar antes de adicionar pilhas."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Отмените её или дождитесь завершения, прежде чем добавлять стеки."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "请先取消或等待其完成，再添加堆栈。"
          }
        }
      }
    },
    "Cancel it or let it finish before opening another project.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Vor dem Öffnen eines anderen Projekts abbrechen oder abschließen lassen."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
