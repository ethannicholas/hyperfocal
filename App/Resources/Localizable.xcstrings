    "Hyperfocal doesn’t have permission to read this project’s images": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Hyperfocal darf die Bilder dieses Projekts nicht lesen"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Hyperfocal no tiene permiso para leer las imágenes de este proyecto"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Hyperfocal n’est pas autorisé à lire les images de ce projet"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Hyperfocal non ha il permesso di leggere le immagini di questo progetto"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Hyperfocalにこのプロジェクトの画像を読む権限がありません"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Hyperfocal에 이 프로젝트의 이미지를 읽을 권한이 없습니다"
          }
        },
