    "Feathered fraction of the brush edge. 0% is hard-edged; 100% fades from the center.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Weich auslaufender Anteil des Pinselrands. 0 % ist hartkantig; 100 % verläuft ab der Mitte."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Fracción difuminada del borde del pincel. 0 % es de borde duro; 100 % se desvanece desde el centro."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Fraction adoucie du bord du pinceau. 0 % : bord net ; 100 % : fondu depuis le centre."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Frazione sfumata del bordo del pennello. 0% è a bordo netto; 100% sfuma dal centro."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ブラシの縁のぼかし割合です。0%はハードエッジ、100%は中心からフェードします。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "브러시 가장자리의 페더링 비율입니다. 0%는 딱딱한 가장자리, 100%는 중심부터 점차 흐려집니다."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Vervaagd deel van de penseelrand. 0% is hardgerand; 100% vervaagt vanaf het midden."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Fração suavizada da borda do pincel. 0% é borda dura; 100% esmaece a partir do centro."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Доля растушёвки края кисти. 0% — жёсткий край; 100% — затухание от центра."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "画笔边缘的羽化比例。0% 为硬边；100% 从中心开始渐隐。"
          }
        }
      }
    },
