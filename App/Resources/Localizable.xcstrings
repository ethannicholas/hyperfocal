    "Moves the black point itself: the very bottom of the range.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Verschiebt den Schwarzpunkt selbst: das untere Ende des Bereichs."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Mueve el propio punto negro: el extremo inferior del rango."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Déplace le point noir lui-même : le bas de la plage."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Sposta il punto di nero stesso: l’estremo inferiore della gamma."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ブラックポイントそのもの（レンジの最下端）を動かします。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "블랙 포인트 자체, 즉 범위의 최하단을 이동합니다."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Verplaatst het zwartpunt zelf: de onderkant van het bereik."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Move o próprio ponto preto: a base do intervalo."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Сдвигает саму точку чёрного: самый низ диапазона."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "移动黑点本身：范围的最底端。"
          }
        }
      }
    },
    "Moves the white point itself: the very top of the range.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Verschiebt den Weißpunkt selbst: das obere Ende des Bereichs."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Mueve el propio punto blanco: el extremo superior del rango."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Déplace le point blanc lui-même : le sommet de la plage."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Sposta il punto di bianco stesso: l’estremo superiore della gamma."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ホワイトポイントそのもの（レンジの最上端）を動かします。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "화이트 포인트 자체, 즉 범위의 최상단을 이동합니다."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Verplaatst het witpunt zelf: de bovenkant van het bereik."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Move o próprio ponto branco: o topo do intervalo."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Сдвигает саму точку белого: самый верх диапазона."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "移动白点本身：范围的最顶端。"
          }
        }
      }
    },
