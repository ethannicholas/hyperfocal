            "value": "ハイライト"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "하이라이트"
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Hoge lichten"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
