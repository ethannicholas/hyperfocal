          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Annulez-la ou laissez-la se terminer avant d’ouvrir un autre projet."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Annullala o lasciala finire prima di aprire un altro progetto."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "別のプロジェクトを開く前に、キャンセルするか完了を待ってください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "다른 프로젝트를 열기 전에 취소하거나 완료될 때까지 기다리세요."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Annuleer die of laat die eerst voltooien voordat u een ander project opent."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Cancele-a ou deixe-a terminar antes de abrir outro projeto."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Отмените её или дождитесь завершения, прежде чем открывать другой проект."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "请先取消或等待其完成，再打开其他项目。"
          }
        }
      }
    },
    "Cancelled at %@.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Bei %@ abgebrochen."
          }
        },
        "es": {
